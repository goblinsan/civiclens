# Root environment example — copy to .env and fill in values

# Database
DATABASE_URL=postgres://user:password@localhost:5432/civreveal

# Congress API
CONGRESS_API_KEY=your_congress_api_key

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Logging
LOG_LEVEL=info
